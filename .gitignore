# Never commit secrets or local state — this repo is workflow config only.
*.credentials*
.credentials.json
*token*
*secret*
*.key
*.pem

# Backups created by init.sh
*.bak-init-*
*.bak

# OS / editor noise
.DS_Store
*.swp

# MemPalace per-project files (issue #185)
mempalace.yaml
entities.json

# MemPalace local memory store (machine-local; lives in $HOME, ignored defensively)
/.mempalace/
mempalace-data/

# Machine-local Claude Code permissions/state (keep .claude/CLAUDE.md trackable)
.claude/settings.local.json

# Visual-plan artifacts and block reference (specs — on-disk reference only)
/plans/
/plan-blocks.md
