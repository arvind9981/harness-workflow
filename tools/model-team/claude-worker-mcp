class BudgetLimitReached(RuntimeError):
    """Claude stopped because the configured per-call budget was exhausted."""

    def __init__(
        self,
        message: str,
        usage: dict[str, int | float] | None = None,
        usage_complete: bool = False,
        provider_turns: int = 0,
    ) -> None:
        super().__init__(message)
        self.usage = usage or {}
        self.usage_complete = usage_complete
        self.provider_turns = provider_turns


class ProviderUsageLimited(RuntimeError):
    """Claude reported a provider usage or session limit."""

    def __init__(self, message: str, blocked_until: float, provider_turns: int = 0) -> None:
        super().__init__(message)
        self.blocked_until = blocked_until
        self.provider_turns = provider_turns


