{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-sol",
  "small_model": "openai/gpt-5.6-luna",
  "provider": {
    "openai": {
      "options": {
        "baseURL": "http://127.0.0.1:8787/v1"
      }
    }
  },
  "mcp": {
    "mempalace": {
      "type": "local",
      "command": [
        "mempalace-mcp"
      ],
      "enabled": true,
      "timeout": 10000
    }
  },
  "tools": {
    "claude-worker_*": false,
    "mempalace_*": false,
    "MCP_DOCKER_*": false
  }
}
