#!/usr/bin/env python3

"""Transparent Codex MCP proxy with worker-only activity instrumentation."""

from __future__ import annotations

import argparse
from datetime import datetime, timezone
import json
import os
from pathlib import Path
import signal
import shutil
import subprocess
import sys
import tempfile
import threading
import time
import tomllib
from typing import Any, TextIO


PASSTHROUGH_CONFIG_KEYS = (
    "model",
    "model_reasoning_effort",
    "openai_base_url",
    "service_tier",
    "personality",
)

WORKER_INSTRUCTIONS = """# Model-Team Codex Worker

Work only on the objective and constraints supplied by the controller.
Never invoke another model-team, agent, or model worker.
Do not access Jira, memory systems, or outward services.
Never commit or push. Do not perform outward actions.
Do not forward secrets, raw transcripts, or unbounded tool output.
Repository edits are allowed only when the handoff explicitly requests implementation.
Verify changed work and return changed files, test evidence, and remaining risks.
"""


def utc_now() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="milliseconds").replace("+00:00", "Z")


def default_state_dir() -> Path:
    override = os.environ.get("MODEL_TEAM_WORKER_STATE_DIR")
    if override:
        return Path(override).expanduser()
    root = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local" / "state"))
    return root / "model-team" / "workers"


def primary_codex_home() -> Path:
    override = os.environ.get("MODEL_TEAM_PRIMARY_CODEX_HOME")
    if override:
        return Path(override).expanduser()
    return Path(os.environ.get("CODEX_HOME", Path.home() / ".codex")).expanduser()


def default_worker_home() -> Path:
    override = os.environ.get("MODEL_TEAM_CODEX_HOME")
    if override:
        return Path(override).expanduser()
    root = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local" / "state"))
    return root / "model-team" / "codex-homes" / str(os.getpid())


def toml_scalar(value: Any, key: str) -> str:
    if isinstance(value, str):
        return json.dumps(value, ensure_ascii=False)
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, (int, float)) and not isinstance(value, bool):
        return str(value)
    raise RuntimeError(f"unsupported {key} value in primary Codex config")


def write_worker_config(worker_home: Path, source: dict[str, Any]) -> None:
    provider = source.get("model_provider")
    if provider not in (None, "openai"):
        raise RuntimeError(
            "model-team worker isolation does not copy custom model providers; "
            "use the built-in OpenAI provider or add an explicit worker provider design"
        )

    values = {key: source[key] for key in PASSTHROUGH_CONFIG_KEYS if key in source}
    values["sandbox_mode"] = "danger-full-access"
    values["approval_policy"] = "never"
    text = "".join(f"{key} = {toml_scalar(value, key)}\n" for key, value in values.items())
    path = worker_home / "config.toml"
    try:
        if path.read_text(encoding="utf-8") == text:
            os.chmod(path, 0o600)
            return
    except FileNotFoundError:
        pass

    fd, temporary = tempfile.mkstemp(prefix=".config.toml.", dir=worker_home)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(text)
        os.chmod(temporary, 0o600)
        os.replace(temporary, path)
    finally:
        if os.path.exists(temporary):
            os.unlink(temporary)


def write_worker_instructions(worker_home: Path) -> None:
    path = worker_home / "AGENTS.md"
    try:
        if path.read_text(encoding="utf-8") == WORKER_INSTRUCTIONS:
            return
    except FileNotFoundError:
        pass
    fd, temporary = tempfile.mkstemp(prefix=".AGENTS.md.", dir=worker_home)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(WORKER_INSTRUCTIONS)
        os.chmod(temporary, 0o600)
        os.replace(temporary, path)
    finally:
        if os.path.exists(temporary):
            os.unlink(temporary)


def link_worker_auth(primary_home: Path, worker_home: Path) -> None:
    source = primary_home / "auth.json"
    destination = worker_home / "auth.json"
    if destination.is_symlink():
        if source.exists() and destination.resolve() == source.resolve():
            return
        destination.unlink()
    elif destination.exists():
        raise RuntimeError(f"refusing to overwrite unmanaged worker credential file: {destination}")

    if source.exists():
        destination.symlink_to(source.resolve())


def prepare_worker_home(primary_home: Path, worker_home: Path) -> Path:
    primary_home = primary_home.absolute()
    worker_home = worker_home.absolute()
    if primary_home == worker_home:
        raise RuntimeError("worker CODEX_HOME must differ from the primary Codex home")

    worker_home.mkdir(parents=True, exist_ok=True, mode=0o700)
    os.chmod(worker_home, 0o700)
    source: dict[str, Any] = {}
    config_path = primary_home / "config.toml"
    try:
        with config_path.open("rb") as handle:
            parsed = tomllib.load(handle)
    except FileNotFoundError:
        parsed = {}
    except tomllib.TOMLDecodeError as exc:
        raise RuntimeError(f"invalid primary Codex config {config_path}: {exc}") from exc
    if not isinstance(parsed, dict):
        raise RuntimeError(f"primary Codex config {config_path} must contain a TOML table")
    source.update(parsed)

    write_worker_config(worker_home, source)
    write_worker_instructions(worker_home)
    link_worker_auth(primary_home, worker_home)
    return worker_home


def configured_model() -> str:
    codex_home = primary_codex_home()
    try:
        with (codex_home / "config.toml").open("rb") as handle:
            model = tomllib.load(handle).get("model")
    except (OSError, tomllib.TOMLDecodeError):
        model = None
    return model if isinstance(model, str) and model else "machine-default"


class WorkerState:
    def __init__(self, state_dir: Path) -> None:
        self.state_dir = state_dir
        self.state_dir.mkdir(parents=True, exist_ok=True)
        self.path = self.state_dir / f"{os.getpid()}.json"
        self.server_started_at = utc_now()
        self.active: dict[str, dict[str, Any]] = {}
        self.started_monotonic: dict[str, float] = {}
        self.latest: dict[str, Any] | None = None
        self.lock = threading.Lock()
        self.write("ready")

    @staticmethod
    def request_key(request_id: Any) -> str:
        return json.dumps(request_id, sort_keys=True, separators=(",", ":"))

    def write(self, status: str) -> None:
        payload = {
            "server_pid": os.getpid(),
            "server_started_at": self.server_started_at,
            "status": status,
            "active_calls": list(self.active.values()),
            "latest": self.latest,
            "updated_at": utc_now(),
        }
        fd, temporary = tempfile.mkstemp(prefix=f".{self.path.name}.", dir=self.state_dir)
        try:
            with os.fdopen(fd, "w", encoding="utf-8") as handle:
                json.dump(payload, handle, separators=(",", ":"))
                handle.write("\n")
            os.chmod(temporary, 0o600)
            os.replace(temporary, self.path)
        finally:
            if os.path.exists(temporary):
                os.unlink(temporary)

    def observe_request(self, message: dict[str, Any]) -> None:
        if message.get("method") != "tools/call" or "id" not in message:
            return
        params = message.get("params")
        if not isinstance(params, dict) or params.get("name") not in {"codex", "codex-reply"}:
            return
        arguments = params.get("arguments")
        if not isinstance(arguments, dict):
            arguments = {}

        tool = params["name"]
        previous = self.latest or {}
        model = arguments.get("model")
        if not isinstance(model, str) or not model:
            model = previous.get("model") if tool == "codex-reply" else None
        if not isinstance(model, str) or not model:
            model = configured_model()

        cwd = arguments.get("cwd")
        if not isinstance(cwd, str):
            cwd = previous.get("cwd", "") if tool == "codex-reply" else ""
        sandbox = arguments.get("sandbox")
        if not isinstance(sandbox, str):
            sandbox = previous.get("sandbox", "") if tool == "codex-reply" else ""

        key = self.request_key(message["id"])
        call = {
            "request_id": message["id"],
            "tool": tool,
            "model": model,
            "cwd": cwd,
            "sandbox": sandbox,
            "started_at": utc_now(),
        }
        with self.lock:
            self.active[key] = call
            self.started_monotonic[key] = time.monotonic()
            self.write("active")

    def observe_response(self, message: dict[str, Any]) -> None:
        if "id" not in message:
            return
        key = self.request_key(message["id"])
        with self.lock:
            call = self.active.pop(key, None)
            started = self.started_monotonic.pop(key, None)
            if call is None:
                return
            result = message.get("result")
            failed = "error" in message or (isinstance(result, dict) and result.get("isError") is True)
            self.latest = {
                **call,
                "completed_at": utc_now(),
                "latency_ms": round((time.monotonic() - started) * 1000) if started is not None else 0,
                "status": "failed" if failed else "passed",
            }
            self.write("active" if self.active else "idle")

    def close(self) -> None:
        try:
            self.path.unlink()
        except FileNotFoundError:
            pass


def decode_json(line: str) -> dict[str, Any] | None:
    try:
        message = json.loads(line)
    except json.JSONDecodeError:
        return None
    return message if isinstance(message, dict) else None


def pump_input(source: TextIO, destination: TextIO, state: WorkerState) -> None:
    try:
        for line in source:
            message = decode_json(line)
            if message is not None:
                state.observe_request(message)
            destination.write(line)
            destination.flush()
    except (BrokenPipeError, OSError):
        pass
    finally:
        try:
            destination.close()
        except OSError:
            pass


def pump_output(source: TextIO, destination: TextIO, state: WorkerState | None = None) -> None:
    try:
        for line in source:
            if state is not None:
                message = decode_json(line)
                if message is not None:
                    state.observe_response(message)
            destination.write(line)
            destination.flush()
    except (BrokenPipeError, OSError):
        pass


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--codex-bin", required=True)
    parser.add_argument("--state-dir", type=Path, default=default_state_dir())
    parser.add_argument("--prepare-only", action="store_true")
    args = parser.parse_args()

    worker_home = prepare_worker_home(primary_codex_home(), default_worker_home())
    ephemeral_home = "MODEL_TEAM_CODEX_HOME" not in os.environ
    if args.prepare_only:
        print(worker_home)
        return 0

    state = WorkerState(args.state_dir.expanduser())
    child_environment = os.environ.copy()
    child_environment["CODEX_HOME"] = str(worker_home)
    child_environment["CODEX_SQLITE_HOME"] = str(worker_home)
    try:
        process = subprocess.Popen(
            [args.codex_bin, "mcp-server"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
            env=child_environment,
        )
    except OSError:
        state.close()
        if ephemeral_home:
            shutil.rmtree(worker_home, ignore_errors=True)
        raise
    assert process.stdin is not None
    assert process.stdout is not None
    assert process.stderr is not None

    def stop_child(_signum: int, _frame: Any) -> None:
        process.terminate()

    signal.signal(signal.SIGINT, stop_child)
    signal.signal(signal.SIGTERM, stop_child)

    threads = [
        threading.Thread(target=pump_input, args=(sys.stdin, process.stdin, state), daemon=True),
        threading.Thread(target=pump_output, args=(process.stdout, sys.stdout, state), daemon=True),
        threading.Thread(target=pump_output, args=(process.stderr, sys.stderr), daemon=True),
    ]
    for thread in threads:
        thread.start()

    try:
        return process.wait()
    finally:
        if process.poll() is None:
            process.terminate()
            try:
                process.wait(timeout=2)
            except subprocess.TimeoutExpired:
                process.kill()
                process.wait(timeout=2)
        for thread in threads[1:]:
            thread.join(timeout=1)
        state.close()
        if ephemeral_home:
            shutil.rmtree(worker_home, ignore_errors=True)


if __name__ == "__main__":
    raise SystemExit(main())
