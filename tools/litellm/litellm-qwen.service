[Unit]
Description=LiteLLM gateway: Anthropic /v1/messages -> local Ollama (qwen3.6), for claude-mem
Documentation=https://docs.claude-mem.ai/configuration/litellm-gateway
After=network.target

[Service]
Type=simple
ExecStart=%h/.local/bin/litellm --config %h/.config/litellm/qwen-proxy.yaml --port 4000 --host 127.0.0.1
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
