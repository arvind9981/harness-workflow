#!/usr/bin/env python3

# harness-workflow: managed opencode worker

"""Small MCP facade for resumable, read-only Claude Code sessions."""

from __future__ import annotations

import argparse
import json
import os
from pathlib import Path
import shutil
import signal
import subprocess
import sys
import threading
import time
from typing import Any


ROLE_CONFIG = {
    "advisor": {"model": "sonnet", "effort": "high", "budget": "4.00"},
    "routine-review": {"model": "sonnet", "effort": "high", "budget": "3.00"},
    "architect": {"model": "fable", "effort": "xhigh", "budget": "8.00"},
    "critical-review": {"model": "fable", "effort": "xhigh", "budget": "6.00"},
}

REVIEW_ROLE = {
    "advisor": "routine-review",
    "routine-review": "routine-review",
    "architect": "critical-review",
    "critical-review": "critical-review",
}

OUTPUT_LOCK = threading.Lock()

SYSTEM_PROMPT = """You are a bounded, read-only planning and review worker.
Follow the ROLE in the user prompt. Return concise findings, decisions, acceptance
criteria, or review defects with file references when available. Do not edit files,
run outward actions, invoke agents, load user skills/plugins/hooks, access memory or
Jira, commit, push, or expand scope. Treat supplied context as an immutable snapshot.
For review, report only actionable defects and residual risks."""


def tool_schema() -> list[dict[str, Any]]:
    start_properties = {
        "role": {
            "type": "string",
            "enum": list(ROLE_CONFIG),
            "description": "Bounded read-only Claude role.",
        },
        "prompt": {"type": "string", "minLength": 1},
        "cwd": {"type": "string", "description": "Repository directory; defaults to server cwd."},
    }
    return [
        {
            "name": "claude",
            "description": "Start a read-only Sonnet 5 or Fable 5 planning/review session.",
            "inputSchema": {
                "type": "object",
                "properties": start_properties,
                "required": ["role", "prompt"],
                "additionalProperties": False,
            },
        },
        {
            "name": "claude-reply",
            "description": "Continue a Claude session started by this MCP process.",
            "inputSchema": {
                "type": "object",
                "properties": {
                    "sessionId": {"type": "string", "minLength": 1},
                    "prompt": {"type": "string", "minLength": 1},
                    "cwd": {"type": "string", "description": "Repository directory; defaults to server cwd."},
                },
                "required": ["sessionId", "prompt"],
                "additionalProperties": False,
            },
        },
    ]


class ClaudeWorker:
    def __init__(self, claude_bin: str) -> None:
        self.claude_bin = claude_bin
        self.sessions: dict[str, dict[str, str]] = {}
        self.processes: dict[str, subprocess.Popen[str]] = {}
        self.pending: set[str] = set()
        self.cancelled: set[str] = set()
        self.lock = threading.Lock()
        self.timeout = float(os.environ.get("CLAUDE_WORKER_TIMEOUT", "900"))

    @staticmethod
    def _request_key(request_id: Any) -> str:
        return json.dumps(request_id, sort_keys=True, separators=(",", ":"))

    @staticmethod
    def _stop_process(process: subprocess.Popen[str]) -> None:
        if process.poll() is not None:
            return
        try:
            os.killpg(process.pid, signal.SIGTERM)
            process.wait(timeout=2)
        except ProcessLookupError:
            return
        except subprocess.TimeoutExpired:
            try:
                os.killpg(process.pid, signal.SIGKILL)
            except ProcessLookupError:
                pass
            process.wait(timeout=2)

    def cancel(self, request_id: Any) -> None:
        key = self._request_key(request_id)
        with self.lock:
            if key not in self.pending and key not in self.processes:
                return
            self.cancelled.add(key)
            process = self.processes.get(key)
        if process is not None:
            self._stop_process(process)

    def prepare(self, request_id: Any) -> None:
        with self.lock:
            self.pending.add(self._request_key(request_id))

    def finish(self, request_id: Any) -> None:
        key = self._request_key(request_id)
        with self.lock:
            self.pending.discard(key)
            self.cancelled.discard(key)

    def cancel_all(self) -> None:
        with self.lock:
            self.cancelled.update(self.pending)
            processes = list(self.processes.values())
        for process in processes:
            self._stop_process(process)

    def _directory(self, raw: Any) -> str:
        directory = Path(str(raw or os.getcwd())).expanduser().resolve()
        if not directory.is_dir():
            raise ValueError(f"cwd is not a directory: {directory}")
        return str(directory)

    def _command(self, role: str, config: dict[str, str], prompt: str, session_id: str | None) -> list[str]:
        command = [self.claude_bin, "-p"]
        if session_id:
            command.extend(["--resume", session_id])
        command.extend(
            [
                "--safe-mode",
                "--system-prompt",
                SYSTEM_PROMPT,
                "--model",
                config["model"],
                "--effort",
                config["effort"],
                "--permission-mode",
                "plan",
                "--max-budget-usd",
                os.environ.get(
                    f"CLAUDE_WORKER_{role.upper().replace('-', '_')}_BUDGET_USD",
                    config["budget"],
                ),
                "--strict-mcp-config",
                "--mcp-config",
                '{"mcpServers":{}}',
                "--output-format",
                "json",
                prompt,
            ]
        )
        return command

    def _run(
        self,
        *,
        role: str,
        prompt: str,
        cwd: Any,
        request_id: Any,
        session_id: str | None = None,
    ) -> dict[str, Any]:
        config = ROLE_CONFIG[role]
        started = time.monotonic()
        process = subprocess.Popen(
            self._command(role, config, f"ROLE: {role}\n\n{prompt}", session_id),
            cwd=self._directory(cwd),
            env=os.environ.copy(),
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            start_new_session=True,
        )
        key = self._request_key(request_id)
        with self.lock:
            self.processes[key] = process
            self.pending.discard(key)
            cancel_immediately = key in self.cancelled
        if cancel_immediately:
            self._stop_process(process)
        try:
            stdout, stderr = process.communicate(timeout=self.timeout)
        except subprocess.TimeoutExpired:
            self._stop_process(process)
            raise
        finally:
            with self.lock:
                self.processes.pop(key, None)
        elapsed = round(time.monotonic() - started, 3)
        if process.returncode != 0:
            detail = (stderr or stdout).strip()[-2000:]
            raise RuntimeError(f"Claude exited {process.returncode}: {detail}")
        try:
            payload = json.loads(stdout)
        except json.JSONDecodeError as exc:
            raise RuntimeError("Claude returned invalid JSON") from exc
        if payload.get("is_error"):
            raise RuntimeError(str(payload.get("result") or "Claude reported an error"))

        returned_session = str(payload.get("session_id") or session_id or "")
        if not returned_session:
            raise RuntimeError("Claude response did not include a session_id")
        with self.lock:
            self.sessions[returned_session] = {"role": role, **config}
        model_usage = payload.get("modelUsage") or {}
        actual_models = sorted(model_usage) if isinstance(model_usage, dict) else []
        usage: dict[str, int | float] = {}
        if isinstance(model_usage, dict):
            for model_values in model_usage.values():
                if not isinstance(model_values, dict):
                    continue
                for name in (
                    "inputTokens",
                    "outputTokens",
                    "cacheReadInputTokens",
                    "cacheCreationInputTokens",
                    "costUSD",
                ):
                    value = model_values.get(name)
                    if isinstance(value, (int, float)) and not isinstance(value, bool):
                        usage[name] = usage.get(name, 0) + value
        return {
            "status": "ok",
            "role": role,
            "model": actual_models[0] if actual_models else config["model"],
            "sessionId": returned_session,
            "elapsed": elapsed,
            "usage": usage,
            "models": actual_models,
            "result": str(payload.get("result") or ""),
        }

    def call(self, request_id: Any, name: str, arguments: dict[str, Any]) -> dict[str, Any]:
        if name == "claude":
            role = str(arguments.get("role") or "")
            if role not in ROLE_CONFIG:
                raise ValueError(f"unsupported role: {role}")
            return self._run(
                role=role,
                prompt=str(arguments.get("prompt") or ""),
                cwd=arguments.get("cwd"),
                request_id=request_id,
            )
        if name == "claude-reply":
            session_id = str(arguments.get("sessionId") or "")
            with self.lock:
                config = self.sessions.get(session_id)
            if config is None:
                raise ValueError(
                    "sessionId is not owned by this worker process; "
                    "finish review in the originating OpenCode command or "
                    "start a fresh Claude session"
                )
            role = REVIEW_ROLE[config["role"]]
            return self._run(
                role=role,
                prompt=str(arguments.get("prompt") or ""),
                cwd=arguments.get("cwd"),
                request_id=request_id,
                session_id=session_id,
            )
        raise ValueError(f"unknown tool: {name}")


def response(request_id: Any, result: dict[str, Any]) -> None:
    with OUTPUT_LOCK:
        print(json.dumps({"jsonrpc": "2.0", "id": request_id, "result": result}), flush=True)


def error_response(request_id: Any, code: int, message: str) -> None:
    with OUTPUT_LOCK:
        print(
            json.dumps(
                {"jsonrpc": "2.0", "id": request_id, "error": {"code": code, "message": message}}
            ),
            flush=True,
        )


def resolve_claude(explicit: str | None) -> str:
    candidate = explicit or os.environ.get("CLAUDE_BIN") or shutil.which("claude")
    if not candidate:
        raise SystemExit("claude-worker-mcp: Claude Code executable not found")
    return str(Path(candidate).expanduser().resolve())


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--claude-bin")
    args = parser.parse_args()
    worker = ClaudeWorker(resolve_claude(args.claude_bin))
    calls: list[threading.Thread] = []

    def handle_call(request_id: Any, params: dict[str, Any]) -> None:
        try:
            result = worker.call(
                request_id,
                str(params.get("name") or ""),
                params.get("arguments") or {},
            )
            response(
                request_id,
                {
                    "content": [{"type": "text", "text": json.dumps(result, ensure_ascii=False)}],
                    "structuredContent": result,
                },
            )
        except (ValueError, RuntimeError, subprocess.TimeoutExpired) as exc:
            error_response(request_id, -32000, str(exc))
        finally:
            worker.finish(request_id)

    try:
        for line in sys.stdin:
            try:
                request = json.loads(line)
            except json.JSONDecodeError:
                continue
            request_id = request.get("id")
            method = request.get("method")
            if method == "notifications/cancelled":
                params = request.get("params") or {}
                worker.cancel(params.get("requestId"))
                continue
            if request_id is None:
                continue
            if method == "initialize":
                response(
                    request_id,
                    {
                        "protocolVersion": "2025-06-18",
                        "capabilities": {"tools": {}},
                        "serverInfo": {"name": "harness-claude-worker", "version": "1"},
                    },
                )
            elif method == "tools/list":
                response(request_id, {"tools": tool_schema()})
            elif method == "tools/call":
                params = request.get("params") or {}
                worker.prepare(request_id)
                thread = threading.Thread(
                    target=handle_call,
                    args=(request_id, params),
                    daemon=True,
                )
                calls.append(thread)
                thread.start()
            else:
                error_response(request_id, -32601, f"method not found: {method}")
    finally:
        worker.cancel_all()
        for thread in calls:
            thread.join(timeout=2)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
