{
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:8787"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.local/bin/headroom init hook ensure --profile init-user --marker headroom-init-claude",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "__HOME__/.claude/hooks/mempalace-context.sh",
            "timeout": 12,
            "statusMessage": "Loading project memory (mempalace)…"
          },
          {
            "type": "command",
            "command": "__HOME__/.claude/hooks/mempalace-health.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "__HOME__/.claude/hooks/mempalace-recap-show.sh",
            "timeout": 5,
            "statusMessage": "Recalling where you left off…"
          },
          {
            "type": "command",
            "command": "__HOME__/.claude/hooks/graphify-reseed-session.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.claude/hooks/mempalace-recap-write.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "test -d __HOME__/.headroom/deploy/init-user || __HOME__/.local/bin/headroom init hook ensure --profile init-user --marker headroom-init-claude",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.claude/hooks/mempalace-recall-enforce.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.claude/hooks/graphify-first-enforce.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.claude/hooks/graphify-autoupdate.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.claude/hooks/mempalace-recall.sh",
            "timeout": 12,
            "statusMessage": "Recalling memory (mempalace)…"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.claude/hooks/mempalace-catchup-rebuild-sessionend.sh",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "headroom@headroom-marketplace": true,
    "mempalace@mempalace": true
  },
  "extraKnownMarketplaces": {
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "headroom-marketplace": {
      "source": {
        "source": "github",
        "repo": "chopratejas/headroom"
      }
    },
    "mempalace": {
      "source": {
        "source": "github",
        "repo": "MemPalace/mempalace"
      }
    }
  },
  "theme": "dark",
  "statusLine": {
    "type": "command",
    "command": "bash __HOME__/.claude/statusline-command.sh"
  }
}