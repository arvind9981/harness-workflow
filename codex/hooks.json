{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "test -d __HOME__/.headroom/deploy/init-user || __HOME__/.local/bin/headroom init hook ensure --profile init-user --marker headroom-init-codex",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.codex/hooks/mempalace-recall-enforce.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.codex/hooks/graphify-first-enforce.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.codex/hooks/graphify-autoupdate.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.local/bin/headroom init hook ensure --profile init-user --marker headroom-init-codex",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "__HOME__/.codex/hooks/headroom-health.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "__HOME__/.codex/hooks/mempalace-context.sh",
            "timeout": 12,
            "statusMessage": "Loading project memory (mempalace)..."
          },
          {
            "type": "command",
            "command": "__HOME__/.codex/hooks/mempalace-health.sh",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "__HOME__/.codex/hooks/mempalace-recap-show.sh",
            "timeout": 3,
            "statusMessage": "Recalling where you left off..."
          },
          {
            "type": "command",
            "command": "__HOME__/.codex/hooks/graphify-reseed-session.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.codex/hooks/mempalace-recall.sh",
            "timeout": 8,
            "statusMessage": "Recalling memory (mempalace)..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.codex/hooks/mempalace-recap-write.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
